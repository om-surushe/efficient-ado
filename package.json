  },
  "homepage": "https://github.com/om-surushe/efficient-ado#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "azure-devops-node-api": "^14.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.10",
    "tsup": "^8.5.1",
